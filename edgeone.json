{
    "name": "another-graph-editor",
    "buildCommand": "pnpm run build",
    "installCommand": "pnpm install",
    "outputDirectory": "./dist",
    "rewrites": [
        {
            "source": "/another_graph_editor/assets/*.css",
            "destination": "/assets/:splat.css"
        },
        {
            "source": "/another_graph_editor/assets/*.js",
            "destination": "/assets/:splat.js"
        }
    ]
}
