{
    "name": "another-graph-editor",
    "buildCommand": "pnpm run build",
    "installCommand": "pnpm install",
    "outputDirectory": "./dist",
    "rewrites": [
        {
            "source": "/another_graph_editor/*",
            "destination": "/another_graph_editor/:splat"
        },
        {
            "source": "/*",
            "destination": "/index.html"
        }
    ]
}
