{
    "name": "another-graph-editor",
    "buildCommand": "pnpm run build",
    "installCommand": "pnpm install",
    "outputDirectory": "./dist",
    "rewrites": [
        {
            "source": "/another_graph_editor/assets/*",
            "destination": "/assets/:splat"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}
